---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getAllBrands } from '@/data/brands-comprehensive';
import { brandToSlug } from '@/utils/comparison';

const brands = getAllBrands();
const nameBySlug = new Map(brands.map((b) => [brandToSlug(b.brand), b.brand]));

const reviews = (await getCollection('reviews'))
  .map((entry) => ({
    id: entry.id,
    title: entry.data.title,
    description: entry.data.seo_description,
    displayName: nameBySlug.get(entry.id) ?? entry.data.brand,
  }))
  .sort((a, b) => a.displayName.localeCompare(b.displayName));
---

<Layout
  title="Platform Reviews & FAQ"
  description="In-depth Taglish reviews of PH online gaming platforms — app download, login, bonuses, GCash cashout at legit checks."
>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>Reviews</span>
    </nav>

    <header class="page-header">
      <h1>Platform Reviews &amp; FAQ</h1>
      <p class="page-subtitle">
        Honest, no-BS Taglish reviews ng mga PH gaming platforms — app download, login,
        bonuses, GCash cashout at legit checks. Pumili ng platform sa baba para sa buong review.
      </p>
    </header>

    {reviews.length === 0 ? (
      <p class="empty">Wala pang review na na-publish. Balik ka mamaya!</p>
    ) : (
      <ul class="review-list">
        {reviews.map((r) => (
          <li class="review-card">
            <a href={`/reviews/${r.id}/`} class="review-card-link">
              <h2>{r.displayName}</h2>
              <p class="review-card-title">{r.title}</p>
              <p class="review-card-desc">{r.description}</p>
              <span class="read-more">Read full review →</span>
            </a>
          </li>
        ))}
      </ul>
    )}

    <p class="cross-link">
      Looking for head-to-head data? Browse the <a href="/all-comparisons">full comparison index</a>.
    </p>
  </div>
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  .breadcrumb span:last-child {
    color: var(--color-text);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    color: var(--color-text-muted);
    max-width: 640px;
  }

  .review-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .review-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color 0.2s;
  }

  .review-card:hover {
    border-color: var(--color-primary);
  }

  .review-card-link {
    display: block;
    padding: 1.5rem;
    color: inherit;
  }

  .review-card h2 {
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 0.35rem;
  }

  .review-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.6rem;
  }

  .review-card-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .empty {
    color: var(--color-text-muted);
  }

  .cross-link {
    margin-top: 2.5rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .cross-link a {
    color: var(--color-primary);
  }
</style>
