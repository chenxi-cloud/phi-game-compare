---
import Layout from '@/layouts/Layout.astro';

// Placeholder shown while the comparison reports are hidden (REPORTS_PUBLIC=false).
// All in-article /reports/* links are rewritten here at build time. noindex so
// this thin page never gets crawled/indexed.
---

<Layout title="Comparison Report — Coming Soon" noindex={true}>
  <div class="container">
    <section class="coming-soon">
      <span class="cs-icon">🛠️</span>
      <h1>Report Under Construction</h1>
      <p class="cs-lead">
        Ginagawa pa namin ang detalyadong head-to-head comparison report na ito. Balik ka
        mamaya — malapit na!
      </p>
      <p class="cs-sub">
        Habang hinihintay, basahin muna ang aming buong platform reviews para sa app download,
        login, bonuses, GCash cashout at legit checks.
      </p>
      <div class="cs-actions">
        <a href="/reviews" class="btn btn-primary">Browse All Reviews →</a>
        <a href="/" class="btn btn-secondary">← Back to Home</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .coming-soon {
    max-width: 560px;
    margin: 3rem auto;
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .cs-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .coming-soon h1 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cs-lead {
    color: var(--color-text);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .cs-sub {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .cs-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
