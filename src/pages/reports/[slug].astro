---
import Layout from '@/layouts/Layout.astro';
import ComparisonSummary from '@/components/comparison/ComparisonSummary.astro';
import CompareModule from '@/components/comparison/CompareModule.astro';
import type { BrandProfile } from '@/types/brand';
import { buildBrandComparison, brandToSlug } from '@/utils/comparison';
import { getBrandLogoUrl } from '@/utils/brand-logo';
import { applySpintaxSummaries } from '@/utils/spintax';
import { getTargetSite, outboundRel, outboundHref } from '@/data/target-site';
import { getCollection } from 'astro:content';
import { REPORTS_PUBLIC } from '@/config/features.mjs';
import comprehensive from '../../../docs/phi_brands_comprehensive.json';

interface RouteProps {
  brandA: BrandProfile;
  brandB: BrandProfile;
}

export async function getStaticPaths() {
  // Soft-launch: keep the report pages in the repo but do not generate them.
  if (!REPORTS_PUBLIC) return [];

  const brands = comprehensive.brands as BrandProfile[];
  const target = getTargetSite();
  const routes: Array<{ slug: string; brandA: BrandProfile; brandB: BrandProfile }> = [];

  // Target site vs every other brand (our promoted site always first).
  for (const brand of brands) {
    routes.push({
      slug: `${brandToSlug(target.brand)}-vs-${brandToSlug(brand.brand)}`,
      brandA: target,
      brandB: brand,
    });
  }

  // Every unique brand pair.
  for (let i = 0; i < brands.length; i++) {
    for (let j = i + 1; j < brands.length; j++) {
      const brandA = brands[i]!;
      const brandB = brands[j]!;
      routes.push({
        slug: `${brandToSlug(brandA.brand)}-vs-${brandToSlug(brandB.brand)}`,
        brandA,
        brandB,
      });
    }
  }

  return routes.map((route) => ({
    params: { slug: route.slug },
    props: { brandA: route.brandA, brandB: route.brandB },
  }));
}

const { brandA, brandB } = Astro.props as RouteProps;
const comparison = applySpintaxSummaries(
  buildBrandComparison(brandA, brandB),
  Astro.params.slug!,
);

const reviewIds = new Set((await getCollection('reviews')).map((e) => e.id));
const brandReviews = [brandA, brandB]
  .map((b) => ({ brand: b, slug: brandToSlug(b.brand) }))
  .filter((b) => reviewIds.has(b.slug));

// FAQ derived from the comparison result — feeds both a visible section and
// FAQPage JSON-LD so the report can qualify for rich snippets.
const withdrawalWinner = comparison.modules.find((m) => m.id === 'withdrawal')?.winnerName;
const overallWinner = comparison.overallWinnerName;

const faqItems = [
  {
    q: `Alin ang mas mabilis mag-withdraw, ${brandA.brand} o ${brandB.brand}?`,
    a: withdrawalWinner
      ? `Base sa aming withdrawal-speed comparison, mas mabilis mag-cash out ang ${withdrawalWinner} sa dalawa.`
      : `Magkapantay ang withdrawal speed ng ${brandA.brand} at ${brandB.brand} base sa aming pagsusuri.`,
  },
  {
    q: `Alin ang mas magandang piliin, ${brandA.brand} o ${brandB.brand}?`,
    a: overallWinner
      ? `Sa aming head-to-head sa withdrawal, customer support, popularity, performance at games, nangunguna ang ${overallWinner} (${comparison.moduleWins.a}-${comparison.moduleWins.b} sa mga module).`
      : `Halos magkapantay ang ${brandA.brand} at ${brandB.brand} sa aming pagsusuri — depende na sa iyong prayoridad kung alin ang pipiliin.`,
  },
  {
    q: `Legit ba ang ${brandA.brand} at ${brandB.brand}?`,
    a: `Parehong nag-o-operate bilang PAGCOR-licensed / regulated na platform ang ${brandA.brand} at ${brandB.brand}. Laging i-verify ang opisyal na site at tapusin ang account verification bago mag-withdraw.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout title={comparison.title} description={comparison.overallSummary}>
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>{comparison.title}</span>
    </nav>

    <header class="report-header">
      <div class="brand-cards">
        {[brandA, brandB].map((b) => (
          <div class:list={['brand-card', { 'brand-card-target': b.is_target }]}>
            <img src={getBrandLogoUrl(b.brand)} alt={b.brand} width="64" height="64" />
            <div class="brand-info">
              <h2>
                {b.brand}
                {b.is_target && <span class="recommended-badge">Recommended</span>}
              </h2>
              <span class="tier-badge">Tier {b.tier}</span>
              <div class="brand-links">
                {b.top_ranking_url && (
                  <a
                    href={outboundHref(b)}
                    target="_blank"
                    rel={outboundRel(b)}
                    class:list={['site-link', { 'site-link-target': b.is_target }]}
                  >
                    Visit Site →
                  </a>
                )}
                {reviewIds.has(brandToSlug(b.brand)) && (
                  <a href={`/reviews/${brandToSlug(b.brand)}/`} class="review-inline-link">
                    Read our {b.brand} review →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      <h1>{comparison.title} — Full Comparison</h1>
    </header>

    <ComparisonSummary comparison={comparison} />

    <div class="modules-section">
      <h2 class="section-heading">Detailed Breakdown</h2>
      <div class="modules-list">
        {comparison.modules.map((mod) => (
          <CompareModule module={mod} brandA={brandA} brandB={brandB} />
        ))}
      </div>
    </div>

    {brandReviews.length > 0 && (
      <section class="review-links">
        <h2 class="section-heading">In-Depth Reviews</h2>
        <p class="review-links-sub">Read the full hands-on review before you decide:</p>
        <div class="review-link-cards">
          {brandReviews.map((r) => (
            <a href={`/reviews/${r.slug}/`} class="review-link-card">
              <span class="review-link-title">{r.brand.brand} Review</span>
              <span class="review-link-cta">Read full review →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="faq-section">
      <h2 class="section-heading">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqItems.map((item) => (
          <details class="faq-item">
            <summary class="faq-q">{item.q}</summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <footer class="report-footer">
      <a href="/" class="btn btn-secondary">← Compare Other Platforms</a>
    </footer>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .breadcrumb span:last-child {
    color: var(--color-text);
  }

  .report-header {
    margin-bottom: 2rem;
  }

  .brand-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .brand-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    flex: 1;
    min-width: 260px;
  }

  .brand-card-target {
    border-color: var(--color-accent);
    background: linear-gradient(135deg, rgba(0, 200, 150, 0.1) 0%, var(--color-surface) 60%);
  }

  .brand-card img {
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    padding: 4px;
  }

  .brand-info h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .recommended-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #04231b;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .site-link-target {
    color: var(--color-accent);
    font-weight: 700;
  }

  .tier-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: rgba(245, 166, 35, 0.15);
    color: var(--color-primary);
    margin-bottom: 0.35rem;
  }

  .brand-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
    margin-top: 0.15rem;
  }

  .site-link {
    display: block;
    font-size: 0.85rem;
  }

  .review-inline-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .review-inline-link:hover {
    color: var(--color-primary);
  }

  .report-header h1 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
  }

  .modules-section {
    margin-bottom: 3rem;
  }

  .section-heading {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 1.25rem;
  }

  .modules-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .review-links {
    margin-bottom: 3rem;
  }

  .review-links-sub {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .review-link-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.75rem;
  }

  .review-link-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color 0.2s;
  }

  .review-link-card:hover {
    border-color: var(--color-primary);
  }

  .review-link-title {
    font-weight: 700;
    color: var(--color-text);
  }

  .review-link-cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .faq-section {
    margin-bottom: 3rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }

  .faq-item[open] {
    border-color: var(--color-primary);
  }

  .faq-q {
    font-weight: 700;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q::before {
    content: '+';
    color: var(--color-primary);
    font-weight: 800;
    margin-right: 0.6rem;
  }

  .faq-item[open] .faq-q::before {
    content: '−';
  }

  .faq-a {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .report-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 2rem;
  }
</style>
