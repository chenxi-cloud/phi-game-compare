---
import type { Site } from '@/types';
import { formatRating } from '@/utils';

interface Props {
  site: Site;
  selected: boolean;
}

const { site, selected } = Astro.props;
---

<label class:list={['site-card', { selected }]} data-slug={site.slug}>
  <input type="checkbox" name="sites" value={site.slug} checked={selected} />
  <div class="card-inner">
    <div class="card-header">
      <img src={site.logo} alt={site.name} width="48" height="48" class="logo" />
      <div class="card-meta">
        <h3 class="site-name">{site.name}</h3>
        <span class="rating">★ {formatRating(site.rating)}</span>
      </div>
    </div>
    <p class="tagline">{site.tagline}</p>
    <div class="highlights">
      {site.highlights.map((h) => <span class="badge">{h}</span>)}
    </div>
    <span class="license">{site.license}</span>
    <span class="check-indicator" aria-hidden="true">✓</span>
  </div>
</label>

<style>
  .site-card {
    position: relative;
    cursor: pointer;
    display: block;
  }

  .site-card input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .card-inner {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    height: 100%;
  }

  .site-card:hover .card-inner {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .site-card.selected .card-inner {
    border-color: var(--color-primary);
    background: rgba(245, 166, 35, 0.06);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .logo {
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    padding: 4px;
  }

  .card-meta {
    flex: 1;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .license {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .check-indicator {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #1a1200;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .site-card.selected .check-indicator {
    display: flex;
  }
</style>
