---
import type { CompareModule as CompareModuleType, BrandProfile, CompareSide } from '@/types/brand';

interface Props {
  module: CompareModuleType;
  brandA: BrandProfile;
  brandB: BrandProfile;
}

const { module, brandA, brandB } = Astro.props;

function cellClass(winner: CompareSide | undefined, side: CompareSide): string {
  if (!winner || winner === 'tie') return '';
  return winner === side ? 'win' : 'lose';
}
---

<section class="compare-module" id={module.id}>
  <div class="module-header">
    <h2>{module.title}</h2>
    {module.winner && module.winner !== 'tie' && module.winnerName && (
      <span class="module-winner">Leader: {module.winnerName}</span>
    )}
    {module.winner === 'tie' && <span class="module-tie">Tie</span>}
  </div>

  <div class="compare-table-wrap">
    <table class="compare-table">
      <thead>
        <tr>
          <th class="col-label">Metric</th>
          <th class="col-brand">{brandA.brand}</th>
          <th class="col-brand">{brandB.brand}</th>
        </tr>
      </thead>
      <tbody>
        {module.rows.map((row) => (
          <tr>
            <td class="col-label">{row.label}</td>
            <td class:list={['col-value', cellClass(row.winner, 'a')]}>{row.valueA}</td>
            <td class:list={['col-value', cellClass(row.winner, 'b')]}>{row.valueB}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="module-summary">
    <strong>Summary</strong>
    <p>{module.summary}</p>
  </div>
</section>

<style>
  .compare-module {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .module-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .module-header h2 {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .module-winner {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: rgba(245, 166, 35, 0.15);
    color: var(--color-primary);
  }

  .module-tie {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: rgba(139, 156, 179, 0.15);
    color: var(--color-text-muted);
  }

  .compare-table-wrap {
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .compare-table th,
  .compare-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    text-align: left;
    vertical-align: top;
  }

  .compare-table thead th {
    background: var(--color-bg);
    font-weight: 600;
    color: var(--color-text);
  }

  .col-label {
    color: var(--color-text-muted);
    width: 28%;
    min-width: 120px;
  }

  .col-brand {
    width: 36%;
  }

  .col-value.win {
    color: var(--color-accent);
    font-weight: 600;
  }

  .col-value.lose {
    color: var(--color-text-muted);
  }

  .module-summary {
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    padding: 1rem 1.25rem;
  }

  .module-summary strong {
    display: block;
    font-size: 0.85rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .module-summary p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }
</style>
